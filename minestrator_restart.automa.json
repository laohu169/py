          "timeout": 90000,
          "context": "website",
          "code": "(async () => {\n  const selector = \"[class*='ring-warning']\";\n  const threshold = \"3h 59m\";\n  const deadline = Date.now() + 60000;\n  let text = \"\";\n\n  while (Date.now() < deadline) {\n    const el = document.querySelector(selector);\n    text = el ? el.textContent.trim() : \"\";\n    if (text.includes(threshold)) {\n      automaSetVariable('shutdownTime', text);\n      automaSetVariable('restartSuccess', true);\n      automaNextBlock({ success: true, shutdownTime: text });\n      return;\n    }\n    await new Promise((resolve) => setTimeout(resolve, 10000));\n  }\n\n  automaSetVariable('shutdownTime', text || 'no_time');\n  automaSetVariable('restartSuccess', false);\n  automaNextBlock({ success: false, shutdownTime: text });\n})().catch((error) => {\n  automaNextBlock({ $error: true, message: error.message });\n});",
