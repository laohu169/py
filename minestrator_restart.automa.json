          "code": "(async () => {\n  const deadline = Date.now() + 120000; // 最多等2分钟\n  while (Date.now() < deadline) {\n    const startBtn = [...document.querySelectorAll('button[data-slot=\"base\"]')]\n      .find(b => b.textContent.trim().includes('Start'));\n    if (startBtn) {\n      startBtn.click();\n      automaNextBlock({ success: true });\n      return;\n    }\n    await new Promise(r => setTimeout(r, 3000));\n  }\n  automaNextBlock({ $error: true, message: 'Server did not go offline within 2 minutes' });\n})().catch((e) => {\n  automaNextBlock({ $error: true, message: e.message });\n});",
